const { execSync, exec } = require('child_process');
const fs = require('fs');
const path = require('path');
const os = require('os');

/**
 * 检查 Node.js 版本
 */
function checkNodeVersion() {
  const [major] = process.versions.node.split('.').map(Number);
  return major >= 18;
}

/**
 * 检测操作系统
 */
function getOS() {
  const platform = os.platform();
  if (platform === 'linux') {
    try {
      const release = fs.readFileSync('/etc/os-release', 'utf8');
      if (release.includes('Ubuntu')) return 'ubuntu';
      if (release.includes('Debian')) return 'debian';
      if (release.includes('CentOS') || release.includes('Rocky')) return 'centos';
      if (release.includes('Fedora')) return 'fedora';
    } catch {}
    return 'linux';
  }
  if (platform === 'darwin') return 'macos';
  if (platform === 'win32') return 'windows';
  return platform;
}

/**
 * 检查 OpenClaw 是否已安装
 */
function isOpenClawInstalled() {
  try {
    const result = execSync('openclaw --version 2>/dev/null || echo "not_found"', {
      encoding: 'utf8',
      timeout: 5000
    });
    return !result.includes('not_found') && !result.includes('command not found');
  } catch {
    return false;
  }
}

/**
 * 获取已安装的 OpenClaw 版本
 */
function getOpenClawVersion() {
  try {
    const result = execSync('openclaw --version 2>/dev/null', {
      encoding: 'utf8',
      timeout: 5000
    });
    return result.trim();
  } catch {
    return null;
  }
}

/**
 * 检查 OpenClaw Gateway 是否正在运行
 */
function isGatewayRunning() {
  try {
    const result = execSync('openclaw gateway status 2>&1', {
      encoding: 'utf8',
      timeout: 10000
    });
    return result.includes('RPC probe: ok');
  } catch {
    return false;
  }
}

/**
 * 检查是否是 root 用户
 */
function isRoot() {
  try {
    return process.getuid && process.getuid() === 0;
  } catch {
    return false;
  }
}

/**
 * 安装 OpenClaw（通过官方 install.sh）
 * install.sh 会自动处理：Node.js、build tools、OpenClaw 安装
 */
async function installOpenClaw(onProgress) {
  const steps = [];
  const report = (name, status, detail) => {
    steps.push({ name, status, detail });
    if (onProgress) onProgress({ name, status, detail, steps: [...steps] });
  };

  try {
    // Step 1: 检测系统
    report('detect_os', 'running', '检测操作系统...');
    const osType = getOS();
    if (osType === 'windows') {
      report('detect_os', 'error', 'Windows 暂不支持，请使用 PowerShell 安装');
      return { success: false, steps };
    }
    report('detect_os', 'done', `${osType} ✓`);

    // Step 2: 检查 curl
    report('check_curl', 'running', '检查 curl...');
    try {
      execSync('curl --version', { encoding: 'utf8', timeout: 5000 });
    } catch {
      report('check_curl', 'error', '未找到 curl，请先安装');
      return { success: false, steps };
    }
    report('check_curl', 'done', 'curl ✓');

    // Step 3: 通过 install.sh 安装
    const sudoPrefix = isRoot() ? '' : 'sudo ';
    report('install_openclaw', 'running',
      isRoot()
        ? '正在通过官方脚本安装 OpenClaw（root 模式，无需密码）...'
        : '正在通过官方脚本安装 OpenClaw（可能需要输入 sudo 密码）...');

    await new Promise((resolve, reject) => {
      const cmd = `curl -fsSL --proto '=https' --tlsv1.2 https://openclaw.ai/install.sh | ${sudoPrefix}bash --no-onboard`;
      const proc = exec(cmd, {
        timeout: 300000,
        shell: '/bin/bash'
      });

      let output = '';
      proc.stdout?.on('data', data => { output += data; });
      proc.stderr?.on('data', data => { output += data; });

      proc.on('close', code => {
        if (code === 0) {
          resolve();
        } else {
          reject(new Error(`安装脚本退出码: ${code}\n${output.slice(-500)}`));
        }
      });
    });
    report('install_openclaw', 'done', 'OpenClaw 安装完成 ✓');

    // Step 4: 安装 ClawHub CLI（Skills 市场需要）
    report('install_clawhub', 'running', '安装 ClawHub CLI...');
    try {
      await new Promise((resolve, reject) => {
        const clawhubCmd = isRoot()
          ? 'npm --loglevel error --no-fund --no-audit install -g clawhub'
          : `sudo npm --loglevel error --no-fund --no-audit install -g clawhub`;
        const proc = exec(clawhubCmd, { timeout: 60000 });
        proc.on('close', code => code === 0 ? resolve() : reject(new Error(`退出码: ${code}`)));
      });
      report('install_clawhub', 'done', 'ClawHub CLI ✓');
    } catch {
      report('install_clawhub', 'done', 'ClawHub 安装跳过（可稍后手动安装）');
    }

    // Step 5: 初始化配置（设置 gateway.mode，确保 Gateway 可启动）
    report('init_config', 'running', '初始化 Gateway 配置...');
    try {
      const configCmd = isRoot()
        ? 'openclaw config set gateway.mode local && openclaw config set gateway.auth.mode none'
        : `openclaw config set gateway.mode local && openclaw config set gateway.auth.mode none`;
      execSync(configCmd, { encoding: 'utf8', timeout: 10000 });
      report('init_config', 'done', 'Gateway 配置完成 ✓');
    } catch {
      report('init_config', 'done', 'Gateway 配置跳过（可稍后手动设置）');
    }

    // Step 6: 验证安装
    report('verify', 'running', '验证安装...');
    try {
      const version = execSync('openclaw --version 2>/dev/null', {
        encoding: 'utf8',
        timeout: 10000
      }).trim();
      report('verify', 'done', `OpenClaw ${version} ✓`);
    } catch {
      report('verify', 'done', '安装完成（需重新打开终端生效）');
    }

    report('all_done', 'done', '🎉 OpenClaw 安装成功！');
    return { success: true, steps };

  } catch (err) {
    report('error', 'error', err.message);
    return { success: false, steps };
  }
}

/**
 * 更新 OpenClaw
 */
async function updateOpenClaw(onProgress) {
  const steps = [];
  const report = (name, status, detail) => {
    steps.push({ name, status, detail });
    if (onProgress) onProgress({ name, status, detail, steps: [...steps] });
  };

  try {
    report('update', 'running', '正在更新 OpenClaw...');
    await new Promise((resolve, reject) => {
      const proc = exec('npm update -g openclaw', { timeout: 120000 });
      proc.on('close', code => code === 0 ? resolve() : reject(new Error(`更新失败，退出码: ${code}`)));
    });
    report('update', 'done', '✅ 更新完成');
    return { success: true, steps };
  } catch (err) {
    report('update', 'error', err.message);
    return { success: false, steps };
  }
}

/**
 * 卸载 OpenClaw
 */
async function uninstallOpenClaw(onProgress) {
  const steps = [];
  const report = (name, status, detail) => {
    steps.push({ name, status, detail });
    if (onProgress) onProgress({ name, status, detail, steps: [...steps] });
  };

  try {
    // Step 1: 停止网关（多种方式，确保停下）
    // 记录 ClawBox 自己的 PID，pkill 时排除
    const selfPid = process.pid;
    report('stop_gateway', 'running', '停止网关...');
    try { execSync('openclaw gateway stop 2>/dev/null', { timeout: 15000 }); } catch {}
    try { execSync('systemctl --user stop openclaw-gateway 2>/dev/null', { timeout: 10000 }); } catch {}
    // 只杀 openclaw-gateway 进程（不是所有含 openclaw 的进程）
    try { execSync('pkill -f "openclaw-gateway" 2>/dev/null', { timeout: 5000 }); } catch {}
    try { execSync('pkill -f "openclaw/dist/index.js" 2>/dev/null', { timeout: 5000 }); } catch {}
    // 等进程退出
    await new Promise(r => setTimeout(r, 2000));
    // 确认已停止（排除 ClawBox 自己）
    try {
      const pids = execSync('pgrep -f "openclaw-gateway" 2>/dev/null || echo ""', { encoding: 'utf8' }).trim();
      if (pids) {
        report('stop_gateway', 'running', '强制终止残留进程...');
        execSync('pkill -9 -f "openclaw-gateway" 2>/dev/null || true', { timeout: 5000 });
        await new Promise(r => setTimeout(r, 1000));
      }
    } catch {}
    report('stop_gateway', 'done', '网关已停止 ✓');

    // Step 2: 卸载 npm 包
    report('uninstall_npm', 'running', '卸载 OpenClaw...');
    let npmSuccess = false;
    try {
      await new Promise((resolve, reject) => {
        const proc = exec('npm uninstall -g openclaw', { timeout: 120000 });
        let output = '';
        proc.stdout?.on('data', d => { output += d; });
        proc.stderr?.on('data', d => { output += d; });
        proc.on('close', code => {
          if (code === 0) resolve();
          else reject(new Error(`npm 卸载退出码: ${code}\n${output}`));
        });
      });
      npmSuccess = true;
      report('uninstall_npm', 'done', 'OpenClaw 已通过 npm 卸载 ✓');
    } catch (err) {
      // npm 卸载失败，强制删除文件
      report('uninstall_npm', 'running', 'npm 卸载失败，强制删除文件...');
      try {
        // 找到 openclaw 的全局安装路径
        const npmRoot = execSync('npm root -g 2>/dev/null', { encoding: 'utf8' }).trim();
        const openclawPath = path.join(npmRoot, 'openclaw');
        if (fs.existsSync(openclawPath)) {
          execSync(`rm -rf "${openclawPath}"`, { timeout: 30000 });
          report('uninstall_npm', 'done', `已强制删除 ${openclawPath} ✓`);
        }
        // 删除 bin 目录下的可执行文件
        try {
          const npmBin = execSync('npm bin -g 2>/dev/null', { encoding: 'utf8' }).trim();
          const binFiles = ['openclaw', 'openclaw-gateway'];
          for (const f of binFiles) {
            const binPath = path.join(npmBin, f);
            if (fs.existsSync(binPath)) {
              execSync(`rm -f "${binPath}"`, { timeout: 5000 });
            }
          }
        } catch {}
        npmSuccess = true;
        report('uninstall_npm', 'done', '已强制清理 OpenClaw 文件 ✓');
      } catch (forceErr) {
        report('uninstall_npm', 'error', `强制删除也失败了: ${forceErr.message}`);
      }
    }

    // Step 3: 清理 systemd 服务
    report('cleanup_service', 'running', '清理 systemd 服务...');
    try {
      execSync('systemctl --user stop openclaw-gateway 2>/dev/null || true', { timeout: 5000 });
      execSync('systemctl --user disable openclaw-gateway 2>/dev/null || true', { timeout: 5000 });
      const svcFile = path.join(os.homedir(), '.config/systemd/user/openclaw-gateway.service');
      if (fs.existsSync(svcFile)) {
        fs.unlinkSync(svcFile);
        execSync('systemctl --user daemon-reload 2>/dev/null || true', { timeout: 5000 });
      }
      report('cleanup_service', 'done', 'systemd 服务已清理 ✓');
    } catch {
      report('cleanup_service', 'done', 'systemd 服务清理跳过');
    }

    // Step 4: 清理配置（可选，保留用户配置）
    report('cleanup', 'done', '配置文件保留在 ~/.openclaw/');

    if (npmSuccess) {
      report('all_done', 'done', '🎉 OpenClaw 已卸载');
    } else {
      report('all_done', 'done', '⚠️ OpenClaw 部分卸载完成（可能有残留）');
    }
    return { success: npmSuccess, steps };
  } catch (err) {
    report('error', 'error', err.message);
    return { success: false, steps };
  }
}

/**
 * 搜索 ClawHub Skills
 */
function searchClawHubSkills(query) {
  const envWithPnpm = { ...process.env, PATH: process.env.PATH + ':/root/.local/share/pnpm:/usr/local/bin' };
  try {
    const result = execSync(`clawhub search --no-input "${query}"`, {
      encoding: 'utf8',
      timeout: 30000,
      env: envWithPnpm
    });
    return { success: true, output: result.trim() };
  } catch (err) {
    return { success: false, error: err.message };
  }
}

/**
 * 安装 ClawHub Skill
 */
function installClawHubSkill(slug) {
  const envWithPnpm = { ...process.env, PATH: process.env.PATH + ':/root/.local/share/pnpm:/usr/local/bin' };
  try {
    const result = execSync(`clawhub install --no-input "${slug}"`, {
      encoding: 'utf8',
      timeout: 60000,
      env: envWithPnpm
    });
    return { success: true, output: result.trim() };
  } catch (err) {
    return { success: false, error: err.message };
  }
}

/**
 * 检查 ClawHub CLI 是否可用
 */
function isClawHubAvailable() {
  // 优先用 which（最可靠）
  try {
    const result = execSync('which clawhub 2>/dev/null || command -v clawhub 2>/dev/null || echo ""', {
      encoding: 'utf8',
      timeout: 5000
    }).trim();
    if (result) return true;
  } catch {}
  return false;
}

/**
 * 安装 ClawHub CLI
 */
function installClawHubCLI() {
  const installCmds = [
    'npm --loglevel error --no-fund --no-audit install -g clawhub',
    'sudo npm --loglevel error --no-fund --no-audit install -g clawhub',
    'pnpm add -g clawhub'
  ];

  for (const cmd of installCmds) {
    try {
      execSync(cmd, { timeout: 60000, stdio: 'ignore' });
      // 安装后确保有执行权限
      try {
        const binPath = execSync('command -v clawhub 2>/dev/null || echo ""', { encoding: 'utf8' }).trim();
        if (binPath) {
          execSync(`chmod +x "${binPath}"`, { stdio: 'ignore' });
        }
      } catch {}
      return { success: true };
    } catch {}
  }
  return { success: false, error: '所有安装方式都失败了' };
}

module.exports = {
  checkNodeVersion,
  getOS,
  isOpenClawInstalled,
  getOpenClawVersion,
  isGatewayRunning,
  isRoot,
  installOpenClaw,
  updateOpenClaw,
  uninstallOpenClaw,
  searchClawHubSkills,
  installClawHubSkill,
  isClawHubAvailable,
  installClawHubCLI
};
